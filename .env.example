# OpenSpawner Configuration
# Copy this file to .env and adjust values as needed
# cp .env.example .env

# ============================================================
# REQUIRED - Must be set before first run
# ============================================================

# Flask session secret - generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# Your domain (use 'localhost' for local development)
BASE_DOMAIN=localhost

# Subdomain for the spawner (e.g. coder -> coder.example.com)
SPAWNER_SUBDOMAIN=coder

# ============================================================
# TRAEFIK - Only needed for production deployment
# ============================================================

# Set to 'true' for production with Traefik reverse proxy
# When 'false' (default for localhost), ports are exposed directly
TRAEFIK_ENABLED=false

# Traefik Docker network (must exist for production)
# TRAEFIK_NETWORK=web

# Traefik certificate resolver name (from your traefik.yml)
# TRAEFIK_CERTRESOLVER=lets-encrypt

# Traefik entrypoint for HTTPS
# TRAEFIK_ENTRYPOINT=websecure

# ============================================================
# DOCKER - Template Configuration
# ============================================================

# Docker socket path (default works for Linux and Docker Desktop)
DOCKER_HOST=unix:///var/run/docker.sock

# Legacy template image (fallback for single-template mode)
USER_TEMPLATE_IMAGE=user-template-01:latest

# Dynamic template list (semicolon-separated)
# Format: image1:tag;image2:tag;image3:tag
#
# Only templates listed here are built by install.sh.
# Template metadata (names, descriptions) is loaded from templates.json.
#
# Available templates:
#   - user-template-01:latest      (Nginx Basic)
#   - user-template-02:latest      (Nginx Advanced)
#   - user-template-next:latest    (Next.js Production)
#   - user-template-dictionary:latest (Dictionary App)
#   - user-template-vcoder:latest  (ESP8266 IDE)
USER_TEMPLATE_IMAGES="user-template-01:latest;user-template-02:latest;user-template-next:latest;user-template-dictionary:latest;user-template-vcoder:latest"

# ============================================================
# RESOURCES - Container Limits
# ============================================================

# RAM limit per user container
DEFAULT_MEMORY_LIMIT=512m

# CPU quota (50000 = 0.5 CPU, 100000 = 1 CPU)
DEFAULT_CPU_QUOTA=50000

# ============================================================
# JWT - Authentication
# ============================================================

# JWT secret (uses SECRET_KEY if not set)
# JWT_SECRET_KEY=

# JWT token validity in seconds (default: 1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600

# ============================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================

# Allowed CORS origins (comma-separated)
# Only set if you need additional origins beyond localhost
# CORS_ORIGINS=https://coder.example.com,http://localhost:3000

# ============================================================
# OPTIONAL - Logging and Debugging
# ============================================================

# Spawner port (internal, for direct access)
SPAWNER_PORT=5000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Container idle timeout in seconds (for auto-shutdown, not yet implemented)
CONTAINER_IDLE_TIMEOUT=3600

# Container creation timeout in seconds
CONTAINER_CREATE_TIMEOUT=10

# ============================================================
# PASSWORDLESS AUTH - Magic Links
# ============================================================

# Magic link token validity in seconds (default: 15 minutes)
MAGIC_LINK_TOKEN_EXPIRY=900

# Max magic links per email address per hour (rate limiting)
MAGIC_LINK_RATE_LIMIT=3

# ============================================================
# EMAIL - Magic Links and Notifications (optional for local dev)
# ============================================================

# SMTP server configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# Frontend URL for email links
# FRONTEND_URL=https://coder.example.com

# ============================================================
# DEBUG & ADMINISTRATION
# ============================================================

# Debug token for admin API
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DEBUG_TOKEN=
